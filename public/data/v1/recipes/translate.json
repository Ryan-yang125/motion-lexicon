  "guidance": {
    "purpose": {
      "zh": "在统一实验台中比较位移、缩放、旋转、倾斜、透视和变换原点。",
      "en": "Compare translation, scale, rotation, skew, perspective, and transform origin in one controlled playground."
    },
    "frequency": {
      "zh": "适合实现前的参数验证；生产界面只保留与当前状态关系有关的变换。",
      "en": "Use during implementation tuning; production UI keeps only transforms that explain the state relationship."
    },
    "trigger": {
      "zh": "由模式选择或状态变化触发，单次只突出一个主要变换维度。",
      "en": "Trigger from mode selection or state change, emphasizing one primary transform dimension at a time."
    },
    "enterExit": {
      "zh": "进入从可解释的偏移状态回到 none；离开沿具有空间含义的方向退出。",
      "en": "Enter from an explainable offset toward none; exit in a direction with spatial meaning."
    },
    "interruptibility": {
      "zh": "切换变换模式时从当前矩阵继续，避免矩阵拆解造成跳变。",
      "en": "Continue from the current transform matrix when switching modes to avoid decomposition jumps."
    },
    "gestureRules": {
      "zh": "拖拽实验将位移与指针一一映射；缩放和旋转控件提供键盘步进。",
      "en": "Map drag experiments directly to pointer travel, with keyboard steps for scale and rotation controls."
    }
  },
  "reducedMotion": {
    "zh": "去除大幅位移、旋转和透视，仅保留状态颜色或短淡入。",
    "en": "Remove large translation, rotation, and perspective, keeping a state-color change or short fade."
  },
  "reviewNotes": [
    {
      "zh": "确认变换不改变文档流和点击区域语义。",
      "en": "Confirm transforms preserve document flow and hit-area semantics."
    },
    {
      "zh": "检查 transform-origin 在缩放和旋转模式中确实可见。",
      "en": "Verify that transform-origin is visibly meaningful in scale and rotation modes."
    }
  ],
